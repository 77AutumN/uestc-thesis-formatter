{
  "university": "电子科技大学",
  "university_en": "University of Electronic Science and Technology of China",
  "template_repo": "https://github.com/MGG1996/DissertationUESTC.git",
  "document_class": "DissertUESTC",
  "template_vendor_dir": "vendor/DissertationUESTC",
  "cls_file": "DissertUESTC.cls",
  "bst_file": "DissertUESTC.bst",
  "font_dir": "font",
  "degree_options": ["bachelor", "master", "promaster", "doctor", "prodoctor", "doublebachelor", "intmaster", "intdoctor"],
  "compile_chain": ["xelatex", "bibtex", "xelatex", "xelatex"],
  "use_latexmk": true,
  "docker_image": "ghcr.io/xu-cheng/texlive-full:latest",
  "quote_style": "mixed",
  "abstract_keywords_delimiter": ",",
  "citation_style": "inline_bracket",
  "bibliography_style": "bibtex",
  "meta_fields": {
    "title": {"zh": true, "en": true},
    "author": {"zh": true, "en": true},
    "advisor": {"zh": true, "en": true, "title_suffix": true, "unit": true, "unit_addr": true},
    "school": {"zh": true, "en": true},
    "major": {"zh": true, "en": true},
    "student_id": true,
    "cls_num": "",
    "udc": "",
    "submit_date": "",
    "defense_date": "",
    "grant_unit": "电子科技大学",
    "grant_date": "",
    "secret_level": "公开"
  },
  "blind_review": false,
  "bib_files": ["ref.bib"],
  "engine": "DissertUESTC",
  "engine_note": "v2 adapter — no CLS patching needed, all macros via template_adapter.py"
}
